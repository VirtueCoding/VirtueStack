{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/storage-backends/layout,_N_T_/storage-backends/page,_N_T_/storage-backends"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/storage-backends/__PAGE__",
    "/storage-backends",
    "/_index",
    "/_head"
  ]
}