      "routeKeys": {},
      "namedRegex": "^/failover\\-requests(?:/)?$"
    },
    {
      "page": "/invoices",
      "regex": "^/invoices(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/invoices(?:/)?$"
    },
    {
      "page": "/ip-sets",
      "regex": "^/ip\\-sets(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/ip\\-sets(?:/)?$"
