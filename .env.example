# =============================================================================
# VirtueStack Environment Configuration
# Copy to .env and fill in values. NEVER commit .env to version control.
# =============================================================================

# --- Controller ---
DATABASE_URL=postgresql://virtuestack:YOUR_PASSWORD_HERE@localhost:5432/virtuestack?sslmode=require
NATS_URL=nats://localhost:4222
JWT_SECRET=generate-a-64-char-hex-secret-here
ENCRYPTION_KEY=generate-a-64-char-hex-encryption-key-here
LISTEN_ADDR=:8080
ALLOW_SELF_REGISTRATION=false
REGISTRATION_EMAIL_VERIFICATION=true

# --- Node Agent ---
CONTROLLER_GRPC_ADDR=controller.internal:50051
NODE_ID=generate-a-uuid-for-this-node
CEPH_POOL=vs-vms
CEPH_USER=virtuestack
CEPH_CONF=/etc/ceph/ceph.conf
TLS_CERT_FILE=/etc/virtuestack/tls/node.crt
TLS_KEY_FILE=/etc/virtuestack/tls/node.key
TLS_CA_FILE=/etc/virtuestack/tls/ca.crt
CLOUDINIT_PATH=/var/lib/virtuestack/cloud-init
ISO_STORAGE_PATH=/var/lib/virtuestack/iso

# --- PowerDNS (rDNS) - Choose one approach ---
# Approach A: Direct MySQL
PDNS_MYSQL_DSN=pdns:YOUR_PASSWORD_HERE@tcp(pdns-db:3306)/powerdns
# Approach B: HTTP API
# PDNS_API_URL=http://pdns:8081
# PDNS_API_KEY=changeme

# --- Email Notifications ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=noreply@example.com
# SMTP_PASSWORD=changeme
# SMTP_FROM=VirtueStack <noreply@example.com>
# SMTP_REQUIRE_TLS=false
# Set SMTP_REQUIRE_TLS=true to enforce STARTTLS on non-465 ports, preventing
# credentials from being sent in plaintext. Recommended for port 587 in production.

# --- Telegram Notifications ---
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF
# TELEGRAM_ADMIN_CHAT_IDS=123456789,987654321

# --- Backups ---
# BACKUP_STORAGE_PATH=/mnt/backups
# BACKUP_FTP_HOST=backup.example.com
# BACKUP_FTP_USER=virtuestack
# BACKUP_FTP_PASSWORD=changeme

# --- Environment ---
APP_ENV=development
# Set to "production" to enforce strong passwords and strict security

# --- Provisioning API IP Allowlist ---
# Comma-separated list of IPs/CIDRs allowed to access /api/v1/provisioning/* endpoints.
# Leave empty to allow all (not recommended for production).
# PROVISIONING_ALLOWED_IPS=10.0.0.1,10.0.0.2,192.168.1.0/24

# --- Logging ---
LOG_LEVEL=info

# --- Billing Provider Configuration ---
# Enable/disable billing providers (only one should be primary)
# BILLING_WHMCS_ENABLED=true
# BILLING_WHMCS_PRIMARY=true
# BILLING_NATIVE_ENABLED=false
# BILLING_NATIVE_PRIMARY=false
# BILLING_BLESTA_ENABLED=false
# BILLING_BLESTA_PRIMARY=false

# --- Native Billing Tuning ---
# BILLING_GRACE_PERIOD_HOURS=12
# BILLING_WARNING_INTERVAL_HOURS=24
# BILLING_NATIVE_AUTO_DELETE_DAYS=0

# --- Stripe Payment Gateway ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- PayPal Payment Gateway ---
# PayPal Orders API v2 credentials.
# Get from https://developer.paypal.com/dashboard/applications
# PAYPAL_CLIENT_ID=your-client-id
# PAYPAL_CLIENT_SECRET=your-client-secret
# PAYPAL_MODE=sandbox
# PAYPAL_WEBHOOK_ID=your-webhook-id
# PAYPAL_RETURN_URL=https://your-domain.com/billing/paypal-return
# PAYPAL_CANCEL_URL=https://your-domain.com/billing

# --- Cryptocurrency Payments ---
# Provider: "btcpay", "nowpayments", or "disabled" (default: disabled)
# Only one crypto provider can be active at a time.
# CRYPTO_PROVIDER=disabled

# BTCPay Server (self-hosted, zero fees)
# Get from your BTCPay Server instance → Store → Access Tokens
# BTCPAY_SERVER_URL=          # e.g., https://btcpay.example.com
# BTCPAY_API_KEY=             # Greenfield API key
# BTCPAY_STORE_ID=            # BTCPay store ID
# BTCPAY_WEBHOOK_SECRET=      # HMAC-SHA256 webhook secret

# NOWPayments (hosted, 0.5% fees)
# Get from https://account.nowpayments.io/
# NOWPAYMENTS_API_KEY=        # NOWPayments API key
# NOWPAYMENTS_IPN_SECRET=     # IPN callback HMAC secret
# NOWPAYMENTS_CALLBACK_URL=https://your-domain.com/api/v1/webhooks/crypto

# Shared crypto settings
# CRYPTO_REDIRECT_URL=https://your-domain.com/billing

# --- OAuth Providers ---
# OAUTH_GOOGLE_ENABLED=false
# OAUTH_GOOGLE_CLIENT_ID=your-google-client-id
# OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
# OAUTH_GITHUB_ENABLED=false
# OAUTH_GITHUB_CLIENT_ID=your-github-client-id
# OAUTH_GITHUB_CLIENT_SECRET=your-github-client-secret

# =============================================================================
# Docker Configuration
# =============================================================================

# --- Docker Image Tags ---
# These should match the defaults in docker-compose.yml
CONTROLLER_TAG=v2.1.0
ADMIN_WEBUI_TAG=v2.1.0
CUSTOMER_WEBUI_TAG=v2.1.0

# --- Build Versions ---
GO_VERSION=1.26
NODE_VERSION=24

# --- PostgreSQL Configuration ---
POSTGRES_USER=virtuestack
POSTGRES_PASSWORD=generate-a-strong-password-here
POSTGRES_DB=virtuestack
POSTGRES_PORT=5432

# --- NATS Configuration ---
NATS_AUTH_TOKEN=your-secure-nats-token-here
NATS_PORT=4222
NATS_HTTP_PORT=8222
NATS_CLUSTER_NAME=virtuestack

# --- Network Configuration ---
CONTROLLER_PORT=8080
ADMIN_PORT=3000
CUSTOMER_PORT=3001
DELVE_PORT=40000

# --- SSL/TLS Configuration ---
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem
# For production, use absolute paths:
# SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem

# --- Next.js Configuration ---
NEXT_PUBLIC_API_URL=/api/v1

# --- Docker Compose Profiles ---
# Uncomment to enable specific profiles
# COMPOSE_PROFILES=production
