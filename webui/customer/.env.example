# Environment Variables for VirtueStack Customer WebUI
# Copy this file to .env.local and fill in the values

# Backend API URL (required)
NEXT_PUBLIC_API_URL=/api/v1

# Feature Flags
# Enable resource configuration section in VM details
NEXT_PUBLIC_ENABLE_RESOURCE_CONFIG=true

# Enable network configuration section in VM details
NEXT_PUBLIC_ENABLE_NETWORK_CONFIG=true

# Enable VM creation button (set to false to disable self-service VM creation)
NEXT_PUBLIC_ENABLE_VM_CREATION=false