{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/backup-schedules/layout,_N_T_/backup-schedules/page,_N_T_/backup-schedules"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/backup-schedules/__PAGE__",
    "/backup-schedules",
    "/_index",
    "/_head"
  ]
}