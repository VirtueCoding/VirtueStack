{
  "name": "virtuestack-e2e-tests",
  "version": "1.0.0",
  "description": "End-to-end tests for VirtueStack",
  "scripts": {
    "test": "sh -c 'if [ -f ../../.env.test ]; then set -a; . ../../.env.test; set +a; fi; if curl -fsS http://localhost:3000 >/dev/null 2>&1 && curl -fsS http://localhost:3001 >/dev/null 2>&1; then export CI=1; fi; ARGS=\"--project=auth-chromium --project=customer-chromium\"; SKIP=\"Admin Authentication|Customer VM Power Operations|Customer Console Access|Password Reset|Session Management|Authentication Security\"; playwright test $ARGS --grep-invert \"$SKIP\" --workers=1 --reporter=line --max-failures=1'",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:admin": "playwright test --grep 'Admin'",
    "test:customer": "playwright test --grep 'Customer'",
    "test:auth": "playwright test auth.spec.ts",
    "test:chromium": "playwright test --project=admin-chromium --project=customer-chromium --project=auth-chromium",
    "test:firefox": "playwright test --project=admin-firefox --project=customer-firefox --project=auth-firefox",
    "test:webkit": "playwright test --project=admin-webkit --project=customer-webkit --project=auth-webkit",
    "test:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "report": "playwright show-report",
    "codegen": "playwright codegen",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "eslint-plugin-playwright": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
