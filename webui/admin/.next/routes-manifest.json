      "routeKeys": {},
      "namedRegex": "^/billing(?:/)?$"
    },
    {
      "page": "/customers",
      "regex": "^/customers(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/customers(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/failover-requests",
